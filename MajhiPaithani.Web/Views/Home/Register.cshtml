@model MajhiPaithani.Web.ViewModels.Home.RegisterViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Majhi Paithani</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Josefin+Sans:wght@200;300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #C9A84C;
            --gold-light: #E8C96B;
            --burgundy: #4A0E1A;
            --deep: #1A0508;
            --silk: #FDF6EC;
            --text-dark: #1e1008;
            --text-mid: #5a3a2a;
        }
        /* --- Elements --- */
        .back-home {
            position: absolute;
            top: 30px;
            left: 30px;
            z-index: 10;
        }

        .back-link {    
            font-family: 'Josefin Sans', sans-serif;
            font-size: 11px;
            letter-spacing: 2px;
            text-decoration: none;
            color: rgba(255, 25, 255, 0.5);
            padding: 10px 18px;
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-radius: 4px;
            transition: 0.3s;
            text-transform: uppercase;
        }

            .back-link:hover {
                color: var(--gold);
                border-color: var(--gold);
                background: rgba(201, 168, 76, 0.05);
            }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cormorant Garamond', Georgia, serif;
            background: linear-gradient(135deg, var(--silk) 0%, #fff5e6 100%);
            min-height: 100vh;
        }

        .bg-pattern {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: radial-gradient(circle at 80% 20%, rgba(201, 168, 76, 0.06) 0%, transparent 50%), radial-gradient(circle at 20% 80%, rgba(74, 14, 26, 0.04) 0%, transparent 50%);
        }

        .register-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            z-index: 2;
        }

        .register-card {
            background: #ffffff;
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-radius: 12px;
            padding: 50px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 60px rgba(74, 14, 26, 0.08);
        }

        .brand-logo {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 900;
            background: linear-gradient(135deg, var(--burgundy) 0%, var(--gold) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 11px;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 8px;
            color: var(--text-dark);
        }

        .form-input, .form-select {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid rgba(201, 168, 76, 0.3);
            border-radius: 4px;
            background: #fafafa;
            font-family: 'Cormorant Garamond', serif;
            font-size: 16px;
        }

        .btn-submit {
            width: 100%;
            padding: 15px;
            background: var(--burgundy);
            color: white;
            border: none;
            border-radius: 4px;
            font-family: 'Josefin Sans', sans-serif;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-submit:hover {
                background: var(--deep);
                transform: translateY(-2px);
            }

        .error-summary {
            background: #fef2f2;
            color: #dc2626;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .password-wrapper {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-mid);
        }
    </style>
</head>
<body>

    <div class="bg-pattern"></div>
    <div class="back-home">
        <a href="/" class="back-link"><i class="fa-solid fa-arrow-left"></i> Home</a>
    </div>

    <div class="register-container">
        <div class="register-card">
            <div style="text-align:center; margin-bottom: 30px;">
                <h1 class="brand-logo">Majhi Paithani</h1>
                <p style="font-family:'Josefin Sans'; font-size:10px; letter-spacing:3px; text-transform:uppercase; color:var(--text-mid);">Join Our Heritage</p>
            </div>

            <h2 style="text-align:center; font-family:'Playfair Display'; margin-bottom:30px;">Create Your Account</h2>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-summary" asp-validation-summary="All"></div>
            }

            <form asp-action="Register" asp-controller="Home" method="post">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="FirstName" class="form-label">First Name *</label>
                        <input asp-for="FirstName" class="form-input" placeholder="Rajesh" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="LastName" class="form-label">Last Name *</label>
                        <input asp-for="LastName" class="form-input" placeholder="Sharma" required />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address *</label>
                    <input asp-for="Email" type="email" class="form-input" placeholder="you@example.com" required />
                </div>

                <div class="form-group">
                    <label asp-for="Phone" class="form-label">Phone Number *</label>
                    <input asp-for="Phone" class="form-input" placeholder="+91 98765 43210" required />
                </div>
                <div class="form-group">
                    <label asp-for="RoleId" class="form-label">I want to *</label>
                    @* Ensure 'name' matches your ViewModel property name exactly *@
                    <select asp-for="RoleId" class="form-select" required>
                        <option value="">Select your role</option>
                        <option value="1">Sell Paithani Sarees (Artisan/Seller)</option>
                        <option value="2">Buy Paithani Sarees (Customer)</option>
                    </select>
                    <span asp-validation-for="RoleId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password *</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" type="password" id="password" class="form-input" required />
                        <button type="button" class="password-toggle" onclick="togglePassword('password')">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm Password *</label>
                    <input type="password" name="ConfirmPassword" class="form-input" id="confirmPassword" required />
                </div>

                <button type="submit" class="btn-submit">Create Account</button>
            </form>

            <div style="text-align:center; margin-top:30px; border-top:1px solid #eee; padding-top:20px;">
                <p style="font-size:14px; color:var(--text-mid);">Already have an account? <a href="/Home/Login" style="color:var(--burgundy); font-weight:600; text-decoration:none;">Sign In</a></p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(id) {
            const input = document.getElementById(id);
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>
</body>
</html>
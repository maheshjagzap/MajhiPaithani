@model MajhiPaithani.Web.ViewModels.Home.LoginViewModel
@* Note: Changed to LoginViewModel as it's more specific for a login post *@

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Majhi Paithani</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Josefin+Sans:wght@200;300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --gold: #C9A84C;
            --gold-light: #E8C96B;
            --gold-pale: #F5E6B8;
            --burgundy: #4A0E1A;
            --deep: #1A0508;
            --silk: #FDF6EC;
            --text-dark: #1e1008;
            --text-mid: #5a3a2a;
            --error: #fca5a5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cormorant Garamond', Georgia, serif;
            background: var(--deep);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
            color: #fff;
        }

        /* --- Background Effects --- */
        .bg-pattern {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: radial-gradient(circle at 20% 50%, rgba(201, 168, 76, 0.08) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(74, 14, 26, 0.15) 0%, transparent 50%);
        }

        .mandala-bg {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 800px;
            height: 800px;
            opacity: 0.03;
            z-index: 1;
            color: var(--gold);
        }

        /* --- Container & Card --- */
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            z-index: 2;
        }

        .login-card {
            background: linear-gradient(135deg, rgba(26, 5, 8, 0.95) 0%, rgba(74, 14, 26, 0.95) 100%);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-radius: 12px;
            padding: 50px 40px;
            max-width: 480px;
            width: 100%;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
            position: relative;
        }

            .login-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
            }

        /* --- Elements --- */
        .back-home {
            position: absolute;
            top: 30px;
            left: 30px;
            z-index: 10;
        }

        .back-link {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 11px;
            letter-spacing: 2px;
            text-decoration: none;
            color: rgba(255, 255, 255, 0.5);
            padding: 10px 18px;
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-radius: 4px;
            transition: 0.3s;
            text-transform: uppercase;
        }

            .back-link:hover {
                color: var(--gold);
                border-color: var(--gold);
                background: rgba(201, 168, 76, 0.05);
            }

        .brand-logo {
            font-family: 'Playfair Display', serif;
            font-size: 38px;
            font-weight: 900;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            letter-spacing: 1px;
        }

        .brand-tagline {
            text-align: center;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 10px;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
            margin-top: 5px;
        }

        .divider-ornament {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin: 25px 0;
            color: var(--gold);
        }

            .divider-ornament span {
                height: 1px;
                flex: 1;
                background: rgba(201, 168, 76, 0.2);
            }

        /* --- Form Styles --- */
        .form-group {
            margin-bottom: 22px;
        }

        .form-label {
            display: block;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 11px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.7);
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            padding: 14px 18px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(201, 168, 76, 0.2);
            border-radius: 4px;
            color: #fff;
            font-family: 'Cormorant Garamond', serif;
            font-size: 16px;
            transition: 0.3s;
        }

            .form-input:focus {
                outline: none;
                border-color: var(--gold);
                background: rgba(201, 168, 76, 0.05);
            }

        .password-wrapper {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: rgba(255,255,255,0.4);
            cursor: pointer;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            color: var(--deep);
            border: none;
            font-family: 'Josefin Sans', sans-serif;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            border-radius: 4px;
            transition: 0.3s;
            margin-top: 10px;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(201, 168, 76, 0.3);
            }

        .error-summary {
            background: rgba(239, 68, 68, 0.1);
            border-left: 3px solid #ef4444;
            padding: 12px;
            margin-bottom: 20px;
            font-size: 14px;
            color: var(--error);
        }

            .error-summary ul {
                list-style: none;
            }

        .social-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 20px;
        }

        .btn-social {
            padding: 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: 0.3s;
        }

            .btn-social:hover {
                background: rgba(201, 168, 76, 0.1);
                border-color: var(--gold);
            }
    </style>
</head>
<body>

    <div class="bg-pattern"></div>

    <div class="mandala-bg">
        <svg viewBox="0 0 500 500" fill="none" stroke="currentColor">
            <circle cx="250" cy="250" r="240" stroke-width="0.5" opacity="0.3" />
            <circle cx="250" cy="250" r="180" stroke-width="0.5" opacity="0.5" />
            <circle cx="250" cy="250" r="120" stroke-width="0.5" opacity="0.7" />
        </svg>
    </div>

    <div class="back-home">
        <a href="/" class="back-link"><i class="fa-solid fa-arrow-left"></i> Home</a>
    </div>

    <div class="login-container">
        <div class="login-card">
            <header>
                <h1 class="brand-logo">Majhi Paithani</h1>
                <p class="brand-tagline">Authentic Heritage</p>
            </header>

            <div class="divider-ornament">
                <span></span>
                <i class="fa-solid fa-crown"></i>
                <span></span>
            </div>

            <h2 style="text-align:center; font-family:'Playfair Display'; margin-bottom:5px;">Welcome Back</h2>
            <p style="text-align:center; color:rgba(255,255,255,0.5); font-style:italic; margin-bottom:30px;">Continue your journey into elegance</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-summary" asp-validation-summary="All"></div>
            }

            <form asp-controller="Home" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-input" placeholder="you@example.com" required />
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="password-wrapper">
                        <input asp-for="Password" type="password" id="password" class="form-input" placeholder="••••••••" required />
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <i id="toggleIcon" class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:25px; font-size:14px;">
                    <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                        @* <input type="checkbox" asp-for="RememberMe" style="accent-color:var(--gold);"> Remember me *@
                    </label>
                    <a href="/Home/ForgotPassword" style="color:var(--gold); text-decoration:none;">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-submit">Sign In</button>
            </form>

            <div style="text-align:center; margin-top:30px; position:relative;">
                <span style="background:var(--burgundy); padding:0 15px; position:relative; z-index:1; font-size:12px; color:rgba(255,255,255,0.4);">OR LOGIN WITH</span>
                <hr style="position:absolute; top:50%; width:100%; border:0; border-top:1px solid rgba(201, 168, 76, 0.2);">
            </div>

            <div class="social-buttons">
                <button class="btn-social"><i class="fa-brands fa-google" style="color:#DB4437;"></i> Google</button>
                <button class="btn-social"><i class="fa-solid fa-mobile-screen-button"></i> Phone</button>
            </div>

            <div style="text-align:center; margin-top:40px; border-top:1px solid rgba(255,255,255,0.1); padding-top:20px;">
                <p style="color:rgba(255,255,255,0.5); font-size:14px; margin-bottom:10px;">New to the Heritage?</p>
                <a href="/Home/Register" style="color:var(--gold); font-family:'Josefin Sans'; letter-spacing:1px; text-transform:uppercase; text-decoration:none; font-weight:600;">Create Account <i class="fa-solid fa-arrow-right-long"></i></a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const field = document.getElementById("password");
            const icon = document.getElementById("toggleIcon");
            if (field.type === "password") {
                field.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                field.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>

</body>
</html>